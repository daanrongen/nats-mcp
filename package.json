{
  "name": "nats-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for NATS — publish, request-reply, JetStream streams, KV store, and server diagnostics over stdio",
  "type": "module",
  "bin": {
    "nats-mcp-server": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "bun run src/main.ts",
    "dev": "bun --watch src/main.ts",
    "build": "bun build src/main.ts --outfile dist/main.js --target bun",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daanrongen/nats-mcp.git"
  },
  "keywords": [
    "mcp",
    "nats",
    "jetstream",
    "model-context-protocol",
    "effect"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "effect": "^3.13.0",
    "nats": "^2.28.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "latest",
    "typescript": "^5.7.2"
  }
}
